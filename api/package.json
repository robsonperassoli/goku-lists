{
  "name": "api",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "bunx tsc --noEmit --ignoreDeprecations 6.0",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio",
    "ngrok": "bun run ngrok.ts"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.6",
    "@elysiajs/cors": "^1.4.1",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "^1.5.6",
    "bun": "^1.3.11",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "better-sqlite3": "^12.8.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
